server {
    listen 443 ssl;
    server_name k8s.vaidhi.sbs;

    ssl_certificate /etc/letsencrypt/live/vaidhi.sbs/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/vaidhi.sbs/privkey.pem;

    # 1. Route for FastAPI
    location /api/ {
    # Adding the slash at the end of the URL tells Nginx
    # to strip the matched "/api/" from the request.
    proxy_pass http://127.0.0.1:8000/;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-Proto $scheme;
}
    # 2. Route for Next.js
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
