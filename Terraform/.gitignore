# .gitignore

# ── Terraform ─────────────────────────────────────────────────────────────────
**/.terraform/
**/.terraform.lock.hcl
**/terraform.tfstate
**/terraform.tfstate.backup
**/tfplan
**/*.tfvars.json

# DO commit *.tfvars (they contain non-secret config)
# DO NOT commit any file named *.auto.tfvars (may contain secrets)
**/*.auto.tfvars

# ── Secrets — never commit ────────────────────────────────────────────────────
*.pem
*.key
*.p12
.env
.env.*
!.env.example

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
dist/
build/
.next/
.nuxt/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
